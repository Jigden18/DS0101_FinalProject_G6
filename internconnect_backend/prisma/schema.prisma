generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  STUDENT
  EMPLOYER
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  PENDING
}

enum ListingStatus {
  ACTIVE
  CLOSED
  PENDING
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

// ─────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  status       Status   @default(PENDING)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student              Student?
  employer             Employer?
  admin                Admin?
  auditLogs            AuditLog[]
  passwordResetTokens  PasswordResetToken[]
}

model Student {
  id             String   @id
  user           User     @relation(fields: [id], references: [id], onDelete: Cascade)
  fullName       String
  university     String
  course         String
  graduationYear Int
  avatarUrl      String?
  bio            String?
  skills         String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  applications Application[]
}

model Employer {
  id            String   @id
  user          User     @relation(fields: [id], references: [id], onDelete: Cascade)
  companyName   String
  contactPerson String
  industry      String
  location      String
  companyBio    String?
  websiteUrl    String?
  companySize   String?
  logoUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listings Listing[]
}

model Admin {
  id          String   @id
  user        User     @relation(fields: [id], references: [id], onDelete: Cascade)
  fullName    String
  permissions String[] @default(["view", "approve", "deactivate"])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Listing {
  id           String        @id @default(uuid())
  employerId   String
  employer     Employer      @relation(fields: [employerId], references: [id], onDelete: Cascade)
  title        String
  description  String
  jobField     String
  location     String
  workHours    String
  stipend      String
  requirements String[]
  deadline     DateTime
  status       ListingStatus @default(ACTIVE)
  postedDate   DateTime      @default(now())
  closedDate   DateTime?
  viewCount    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  applications Application[]
}

model Application {
  id             String            @id @default(uuid())
  studentId      String
  student        Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  listingId      String
  listing        Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  coverLetter    String
  resumeUrl      String
  resumeFilename String
  status         ApplicationStatus @default(SUBMITTED)
  appliedDate    DateTime          @default(now())
  reviewedDate   DateTime?
  reviewNotes    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([studentId, listingId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  action       String
  resourceType String
  resourceId   String?
  details      Json?
  timestamp    DateTime @default(now())
}
